                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/accounts/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "accounts",
                "register"
              ]
            },
            "description": "- **Description**: Create a new user account.\n    \n- **Function**: Accepts user credentials (Username, Email, Password) and stores a new record in the database with an \"Inactive\" status until verified."
          },
          "response": []
        },
        {
          "name": "Send Activation Account Code",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"email\": \"{{user_email}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
